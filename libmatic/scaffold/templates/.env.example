# libmatic 用の secrets。`.env` にコピーして値を埋めること。
# 本番 (GitHub Actions) では Repository / Organization の Secrets に登録すること。

# Anthropic API キー (必須)
ANTHROPIC_API_KEY=

# GitHub Personal Access Token (issue/PR 操作用)
# 必要 scope: repo, workflow
GH_TOKEN=

# (optional) Tavily API key — web_search を tavily 経由にする場合
# TAVILY_API_KEY=
